# Identity hashing salt
ID_SALT=mateclaw-agent_secure_default

# Session storage
ADK_SESSION_SERVICE_URI=sqlite+aiosqlite:////app/data/mateclaw_agent.db

# Timezone
TIMEZONE=UTC

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# LINE Bot
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Discord Bot
DISCORD_BOT_TOKEN=

# Email (SMTP) notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# Model provider (gemini / litellm)
MATECLAW_AGENT_MODEL_PROVIDER=gemini
MATECLAW_AGENT_GEMINI_MODEL=gemini-2.5-flash

# Google Gemini
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=

# LiteLLM (only needed if MATECLAW_AGENT_MODEL_PROVIDER=litellm)
LITELLM_API_BASE=
LITELLM_API_KEY=
LITELLM_MODEL_NAME=
LITELLM_SKIP_SPECIAL_TOKENS=False

# PostgreSQL (only needed if using PostgreSQL session storage)
POSTGRES_USER=mateclaw
POSTGRES_PASSWORD=mateclaw_pass
POSTGRES_DB=mateclaw_db
POSTGRES_PORT=5432

# MCP server URL map (JSON) — managed by `mateclaw` CLI
MCP_SERVER_URLS={"mateclaw": "http://mcp-mateclaw:8081/sse"}

# External agents A2A URLs — managed by `mateclaw agent deploy`
CODING_A2A_URL=
EXTERNAL_AGENTS_CONFIG=

# Port bindings (host side)
MATECLAW_AGENT_PORT=18080
MCP_MATECLAW_PORT=8081

# MCP / API security keys — managed by `mateclaw` CLI
MCP_SECRET_KEY=
API_HEADERS_KEY=
