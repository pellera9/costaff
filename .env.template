# =============================================================================
# CoStaff Core Configuration
# =============================================================================
# Instructions:
#   1. Copy this file to .env  →  cp .env.template .env
#   2. Fill in all [REQUIRED] fields
#   3. Pick one option in [REQUIRED — pick one] sections
#   4. Leave [AUTO] fields alone — the `costaff` CLI manages them
#
# Channel and agent configuration is handled separately when you run
# `costaff channel add` or `costaff agent deploy`.
# =============================================================================


# -----------------------------------------------------------------------------
# SECURITY  [REQUIRED]
# -----------------------------------------------------------------------------

# Random string used to hash user IDs — set before first run, never change after
ID_SALT=change-me-to-a-random-string

# Secret key for MCP internal communication  [AUTO — set by `costaff init`]
MCP_SECRET_KEY=

# Secret key for API header authentication  [AUTO — set by `costaff init`]
API_HEADERS_KEY=


# -----------------------------------------------------------------------------
# GENERAL  [REQUIRED]
# -----------------------------------------------------------------------------

# Timezone for scheduling and logs (e.g. Asia/Taipei, UTC, America/New_York)
TIMEZONE=UTC

# Language for agent responses (e.g. "Traditional Chinese (繁體中文)", "English")
COSTAFF_PREFERRED_LANGUAGE=Traditional Chinese (繁體中文)


# -----------------------------------------------------------------------------
# SESSION STORAGE  [REQUIRED]
# -----------------------------------------------------------------------------
# CoStaff requires PostgreSQL. SQLite is not supported by the MCP server
# container; the `costaff start` Postgres service in docker-compose.yaml
# satisfies the URI below out of the box.
#
# IMPORTANT: order matters. docker compose interpolates `${VAR}` in env_file
# top-down — if ADK_SESSION_SERVICE_URI appears before POSTGRES_USER, the
# interpolation produces an empty user and the manager auth-fails against
# postgres as "root". Keep POSTGRES_* defined first.

POSTGRES_USER=costaff
POSTGRES_PASSWORD=costaff_pass
POSTGRES_DB=costaff_db
POSTGRES_PORT=5432

ADK_SESSION_SERVICE_URI=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}


# -----------------------------------------------------------------------------
# AI MODEL  [REQUIRED — pick one provider]
# -----------------------------------------------------------------------------

# Active provider: "gemini" or "litellm"
COSTAFF_AGENT_MODEL_PROVIDER=gemini

# -- Option A: Google Gemini (default) ---------------------------------------
# Get API key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
COSTAFF_AGENT_GEMINI_MODEL=gemini-3-flash-preview

# Set to 1 if using Vertex AI instead of AI Studio
GOOGLE_GENAI_USE_VERTEXAI=0

# -- Option B: LiteLLM (OpenAI-compatible, any provider) --------------------
# Only fill these if COSTAFF_AGENT_MODEL_PROVIDER=litellm
LITELLM_API_BASE=
LITELLM_API_KEY=
LITELLM_MODEL_NAME=
LITELLM_SKIP_SPECIAL_TOKENS=False


# -----------------------------------------------------------------------------
# PORTS  [OPTIONAL — change only if defaults conflict with your system]
# -----------------------------------------------------------------------------

COSTAFF_AGENT_PORT=18080
MCP_COSTAFF_PORT=8081


# -----------------------------------------------------------------------------
# INTERNAL  [AUTO — managed by `costaff` CLI, do not edit manually]
# -----------------------------------------------------------------------------

MCP_SERVER_URLS={"costaff": "http://costaff-mcp-costaff:8081/mcp"}
EXTERNAL_AGENTS_CONFIG=
