# Identity hashing salt
ID_SALT=costaff-agent_secure_default

# Session storage
ADK_SESSION_SERVICE_URI=sqlite+aiosqlite:////app/data/costaff_agent.db

# Timezone
TIMEZONE=UTC

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# LINE Bot
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Discord Bot
DISCORD_BOT_TOKEN=

# Email (SMTP) notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# Model provider (gemini / litellm)
COSTAFF_AGENT_MODEL_PROVIDER=gemini
COSTAFF_AGENT_GEMINI_MODEL=gemini-2.5-flash

# Google Gemini
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=

# LiteLLM (only needed if COSTAFF_AGENT_MODEL_PROVIDER=litellm)
LITELLM_API_BASE=
LITELLM_API_KEY=
LITELLM_MODEL_NAME=
LITELLM_SKIP_SPECIAL_TOKENS=False

# PostgreSQL (only needed if using PostgreSQL session storage)
POSTGRES_USER=costaff
POSTGRES_PASSWORD=costaff_pass
POSTGRES_DB=costaff_db
POSTGRES_PORT=5432

# MCP server URL map (JSON) — managed by `costaff` CLI
MCP_SERVER_URLS={"costaff": "http://mcp-costaff:8081/sse"}

# External agents A2A URLs — managed by `costaff agent deploy`
CODING_A2A_URL=
EXTERNAL_AGENTS_CONFIG=

# Port bindings (host side)
COSTAFF_AGENT_PORT=18080
MCP_COSTAFF_PORT=8081

# MCP / API security keys — managed by `costaff` CLI
MCP_SECRET_KEY=
API_HEADERS_KEY=
